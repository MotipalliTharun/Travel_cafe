# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=trailorr
POSTGRES_PASSWORD=trailorr
POSTGRES_DB=trailorr
DB_PORT=5433

# ── JWT ───────────────────────────────────────────────────────────────────────
